[MAIN]

# Add files or directories matching the regular expressions patterns to the
# ignore-list. The regex matches against paths and can be in Posix or Windows
# format. Because '\\' represents the directory delimiter on Windows systems,
# it can't be used as an escape character.
ignore-paths=^docs/.*$,
             ^dist/.*$,
             ^tests/sample_pancad_objects/.*$,
             ^tests/test_cad/.*$,
             ^tests/test_filetypes/.*$,
             ^tests/test_geometry/test_circle.py$,
             ^tests/test_geometry/test_circular_arc.py$,
             ^tests/test_geometry/test_coincident.py$,
             ^tests/test_geometry/test_coordinate_system.py$,
             ^tests/test_geometry/test_distance.py$,
             ^tests/test_geometry/test_ellipse.py$,
             ^tests/test_geometry/test_extrude.py$,
             ^tests/test_geometry/test_feature_system.py$,
             ^tests/test_geometry/test_horizontal.py$,
             ^tests/test_geometry/test_line.py$,
             ^tests/test_geometry/test_line_segment.py$,
             ^tests/test_geometry/test_plane.py$,
             ^tests/test_geometry/test_shared_geometry.py$,
             ^tests/test_geometry/test_sketch.py$,
             ^tests/test_geometry/test_sketch_geometry_system.py$,
             ^tests/test_geometry/test_spatial_relations.py$,
             ^tests/test_geometry/test_storage.py$,
             ^tests/test_geometry/test_vertical.py$,
             ^tests/test_svg/.*$,
             ^tests/test_utils/.*$,
             ^tests/utils/.*$,
             ^tests/conftest.py$,
             ^tests/test_file_handlers.py$,
             ^tests/test_pancad_init.py$,
             ^tests/test_public_interface.py$,
             ^tests/test_svg_element_utils.py$,
             ^tests/test_svg_elements.py$,
             ^tests/test_svg_file.py$,
             ^tests/test_svg_generators.py$,
             ^tests/test_svg_parsers.py$,
             ^tests/test_svg_validators.py$,

[DESIGN]

# Maximum number of arguments for function / method.
max-args=7

# Maximum number of positional arguments for function / method.
max-positional-arguments=7

[TYPECHECK]

# List of members which are set dynamically and missed by pylint inference
# system, and so shouldn't trigger E1101 when accessed. Python regular
# expressions are accepted.
generated-members=self.spherical.r,
                  self.spherical.phi,
                  self.spherical.theta,
                  self.polar.r,
                  self.polar.phi,
                  freecad.open,
                  freecad.DocumentObject
                  freecad.Document,
                  freecad.Placement,
                  freecad.newDocument,
                  freecad.Vector,
                  freecad.Units